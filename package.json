{
  "name": "plumbline",
  "version": "0.1.0",
  "description": "Lints MCP client config files across Claude Desktop, Cursor and VS Code — knows each client's schema and pitfalls, with a fix and a stable code on every finding.",
  "author": "JaydenCJ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "plumbline": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "linter",
    "config",
    "claude-desktop",
    "cursor",
    "vscode",
    "cli"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/plumbline.git"
  },
  "homepage": "https://github.com/JaydenCJ/plumbline#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/plumbline/issues"
  }
}
